NEXUS_API_KEY=your_openai_api_key
NEXUS_BASE_URL=https://api.openai.com/v1
NEXUS_MODEL=gpt-4o
NEXUS_MAX_CONTEXT=128000
NEXUS_MAX_ATTEMPTS=256

NEXUS_GITHUB_REPO=owner/repo
NEXUS_GITHUB_TOKEN=your_tela_github_token
NEXUS_SOPHIE_GITHUB_TOKEN=your_sophie_github_token
NEXUS_MARC_GITHUB_TOKEN=your_marc_github_token

NEXUS_DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus
NEXUS_REDIS_URL=redis://localhost:6379/0
NEXUS_REDIS_MESSAGE_TTL_SECONDS=86400

NEXUS_CELERY_BROKER_URL=redis://localhost:6379/0
NEXUS_CELERY_RESULT_BACKEND=redis://localhost:6379/0
NEXUS_CELERY_QUEUE=nexus_agent_tasks
NEXUS_CELERY_VISIBILITY_TIMEOUT_SECONDS=86400
NEXUS_CELERY_TASK_PUBLISH_MAX_RETRIES=3
NEXUS_CELERY_BROKER_CONNECTION_TIMEOUT_SECONDS=2.0
NEXUS_TASK_DISPATCH_LEASE_SECONDS=60

NEXUS_GITHUB_FEEDBACK_POLL_INTERVAL_SECONDS=60
NEXUS_GITHUB_FEEDBACK_POLL_TASK_LIMIT=100
NEXUS_GITHUB_FEEDBACK_BATCH_SIZE=20
NEXUS_GITHUB_FEEDBACK_HTTP_TIMEOUT_SECONDS=10.0

# GitHub OAuth login
# Create a GitHub OAuth App and set Authorization callback URL to:
#   http://localhost:6515/v1/auth/github/callback
# Use your deployed API host instead of localhost in production.
NEXUS_GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
NEXUS_GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret
NEXUS_GITHUB_OAUTH_REDIRECT_URI=http://localhost:6515/v1/auth/github/callback
NEXUS_AUTH_SESSION_COOKIE_NAME=nexus_session
NEXUS_AUTH_SESSION_TTL_SECONDS=2592000

NEXUS_PRODUCT_DISCOVERY_POLL_INTERVAL_SECONDS=10
NEXUS_PRODUCT_DISCOVERY_POLL_TASK_LIMIT=100
