NEXUS_API_KEY=change_me
NEXUS_BASE_URL=https://api.openai.com/v1
NEXUS_MODEL=gpt-4o
NEXUS_MAX_CONTEXT=128000
NEXUS_MAX_ATTEMPTS=256

NEXUS_GITHUB_REPO=owner/repo
NEXUS_GITHUB_TOKEN=change_me
NEXUS_SOPHIE_GITHUB_TOKEN=change_me
NEXUS_MARC_GITHUB_TOKEN=change_me

POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change_me_strong_password
NEXUS_DATABASE_URL=postgresql+asyncpg://nexus:change_me_strong_password@postgres:5432/nexus

NEXUS_REDIS_URL=redis://redis:6379/0
NEXUS_REDIS_MESSAGE_TTL_SECONDS=86400
NEXUS_CELERY_BROKER_URL=redis://redis:6379/0
NEXUS_CELERY_RESULT_BACKEND=redis://redis:6379/0
NEXUS_CELERY_QUEUE=nexus_agent_tasks
NEXUS_CELERY_LOG_LEVEL=INFO
NEXUS_CELERY_VISIBILITY_TIMEOUT_SECONDS=86400
NEXUS_CELERY_TASK_PUBLISH_MAX_RETRIES=3
NEXUS_CELERY_BROKER_CONNECTION_TIMEOUT_SECONDS=2.0
NEXUS_TASK_DISPATCH_LEASE_SECONDS=60

NEXUS_GITHUB_FEEDBACK_POLL_INTERVAL_SECONDS=60
NEXUS_GITHUB_FEEDBACK_POLL_TASK_LIMIT=100
NEXUS_GITHUB_FEEDBACK_BATCH_SIZE=20
NEXUS_GITHUB_FEEDBACK_HTTP_TIMEOUT_SECONDS=10.0
NEXUS_FRONTEND_BASE_URL=https://your-frontend-domain.example.com
NEXUS_PRODUCT_DISCOVERY_POLL_INTERVAL_SECONDS=10
NEXUS_PRODUCT_DISCOVERY_POLL_TASK_LIMIT=100
NEXUS_PRODUCT_DISCOVERY_PENDING_PROPOSAL_LIMIT=3
NEXUS_PRODUCT_DISCOVERY_COOLDOWN_SECONDS=86400
NEXUS_PRODUCT_DISCOVERY_RECENT_CONTEXT_LIMIT=5
